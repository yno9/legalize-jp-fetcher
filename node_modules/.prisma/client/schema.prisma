generator client {
  provider = "prisma-client-js"
}

generator batchClient {
  provider = "prisma-client-js"
  output   = "../../batch/node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Law {
  lawId        String     @id @map("law_id")
  lawNum       String     @map("law_num")
  title        String
  titleKana    String?    @map("title_kana")
  lawType      String     @map("law_type")
  category     String?
  repealStatus String?    @map("repeal_status")
  updatedAt    DateTime?  @map("updated_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  revisions    Revision[]

  @@map("laws")
}

model Revision {
  revisionId       String       @id @map("revision_id")
  lawId            String       @map("law_id")
  promulgatedAt    DateTime?    @map("promulgated_at") @db.Date
  enforcedAt       DateTime     @map("enforced_at") @db.Date
  amendmentLawId   String?      @map("amendment_law_id")
  amendmentLawNum  String?      @map("amendment_law_num")
  amendmentLawName String?      @map("amendment_law_name")
  isFuture         Boolean      @default(false) @map("is_future")
  createdAt        DateTime     @default(now()) @map("created_at")
  law              Law          @relation(fields: [lawId], references: [lawId])
  elements         LawElement[]

  @@index([lawId, enforcedAt])
  @@map("revisions")
}

model LawElement {
  id          Int          @id @default(autoincrement())
  revisionId  String       @map("revision_id")
  parentId    Int?         @map("parent_id")
  elementType String       @map("element_type")
  num         String?
  title       String?
  text        String?
  orderIndex  Int          @map("order_index")
  path        String
  revision    Revision     @relation(fields: [revisionId], references: [revisionId])
  parent      LawElement?  @relation("LawElementTree", fields: [parentId], references: [id])
  children    LawElement[] @relation("LawElementTree")

  @@index([revisionId, path])
  @@index([revisionId])
  @@map("law_elements")
}
