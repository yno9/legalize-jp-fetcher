                    {
                      "tag": "ParagraphSentence",
                      "attr": {},
                      "children": [
                        {
                          "tag": "Sentence",
                          "attr": {
                            "Num": "1",
                            "WritingMode": "vertical"
                          },
                          "children": [
                            "法人の代表者又は法人若しくは人の代理人、使用人その他の従業者が、その法人又は人の業務に関して前二条の罪を犯したときは、行為者を罰するほか、その法人又は人に対して各本条の罰金刑を科する。"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "tag": "Article",
              "attr": {
                "Num": "5"
              },
              "children": [
                {
                  "tag": "ArticleCaption",
                  "attr": {},
                  "children": [
                    "（推定）"
                  ]
                },
                {
                  "tag": "ArticleTitle",
                  "attr": {},
                  "children": [
                    "第五条"
                  ]
                },
                {
