                  "children": [
                    "（趣旨）"
                  ]
                },
                {
                  "tag": "ArticleTitle",
                  "attr": {},
                  "children": [
                    "第一条"
                  ]
                },
                {
                  "tag": "Paragraph",
                  "attr": {
                    "Num": "1"
                  },
                  "children": [
                    {
                      "tag": "ParagraphNum",
