                          "tag": "ArticleCaption",
                          "attr": {},
                          "children": [
                            "（説明又は資料提出の要求等）"
                          ]
                        },
                        {
                          "tag": "ArticleTitle",
                          "attr": {},
                          "children": [
                            "第九条"
                          ]
                        },
                        {
                          "tag": "Paragraph",
                          "attr": {
                            "Num": "1"
                          },
                          "children": [
                            {
                              "tag": "ParagraphNum",
                              "attr": {},
