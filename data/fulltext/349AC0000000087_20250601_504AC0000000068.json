                {
                  "tag": "ArticleCaption",
                  "attr": {},
                  "children": [
                    "（過失犯）"
                  ]
                },
                {
                  "tag": "ArticleTitle",
                  "attr": {},
                  "children": [
                    "第六条"
                  ]
                },
                {
                  "tag": "Paragraph",
                  "attr": {
                    "Num": "1"
                  },
                  "children": [
                    {
                      "tag": "ParagraphNum",
                      "attr": {},
                      "children": []
                    },
                    {
