                  "children": [
                    "第七条"
                  ]
                },
                {
                  "tag": "Paragraph",
                  "attr": {
                    "Num": "1"
                  },
                  "children": [
                    {
                      "tag": "ParagraphNum",
                      "attr": {},
                      "children": []
                    },
                    {
                      "tag": "ParagraphSentence",
                      "attr": {},
                      "children": [
                        {
                          "tag": "Sentence",
                          "attr": {
                            "Num": "1",
                            "WritingMode": "vertical"
                          },
                          "children": [
                            "第一条から第五条までの罪は、刑法（明治四十年法律第四十五号）第二条の例に従う。"
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
