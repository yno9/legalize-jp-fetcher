                      "attr": {},
                      "children": [
                        "この法律は、公布の日から施行する。"
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "tag": "Paragraph",
              "attr": {
                "Num": "2"
              },
              "children": [
                {
                  "tag": "ParagraphCaption",
                  "attr": {},
                  "children": [
                    "（最高裁判所による検証の結果の最初の公表）"
                  ]
                },
                {
